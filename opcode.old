
    if (modrm == "E")
    {
        uint16_t disp = Fetch16();

        uint32_t addr = (cpu.ds << 4) + disp;


// ADD THESE LINES HERE
printf("DS=%04X DISP=%04X ADDR=%05X\n", cpu.ds, disp, addr);

printf("MEMORY: ");
for (int i = 0; i < 8; i++)
    printf("%02X ", memory[addr + i]);
printf("\n");

// Existing code
        printf("DS=%04X DISP=%04X ADDR=%05X\n",
               cpu.ds, disp, addr);

        printf("PTR BYTES: %02X %02X %02X %02X\n",
               memory[addr],
               memory[addr + 1],
               memory[addr + 2],
               memory[addr + 3]);

        uint16_t newIP = memory[addr] | (memory[addr + 1] << 8);
        uint16_t newCS = memory[addr + 2] | (memory[addr + 3] << 8);

        printf("CALL FAR -> %04X:%04X\n", newCS, newIP);

        Push16(cpu.cs);
        Push16(cpu.ip);
if(newCS >= 0xF000)
{
    printf("CALL FAR to system area %04X:%04X ignored\n", newCS, newIP);
    return;
}
        cpu.cs = newCS;
        cpu.ip = newIP;
        return;
    }
